rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check user role
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Events: Publicly readable, write restricted to authenticated organizers/admins
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null && getUserData().role in ['organizer', 'admin'];
      allow update, delete: if request.auth != null && (resource.data.organizerId == request.auth.uid || getUserData().role == 'admin');
    }
    
    // Tickets: Users can read/create their own. Organizers of the associated event can read/update (for scanner check-in). Admins can read all.
    match /tickets/{ticketId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid ||
        getUserData().role == 'admin'
      );
      
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid ||
        getUserData().role == 'admin'
      );
      
      allow delete: if request.auth != null && getUserData().role == 'admin';
    }
    
    // Users: Users can read/write their own profile data. Admins can read all profiles.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || getUserData().role == 'admin');
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Trails: Publicly readable, write restricted to admins.
    match /trails/{trailId} {
      allow read: if true;
      allow write: if request.auth != null && getUserData().role == 'admin';
    }
  }
}
